# Server
NODE_ENV=development
PORT=3002
TZ=Asia/Tehran

# Database
DATABASE_URL=postgresql://approval_user:approval_pass@db:5432/approvals

# Auth
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_EXPIRES_IN=8h

# File storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
FILE_ENCRYPTION_KEY=change-me-to-a-32-byte-hex-string-64-chars

# Frontend
FRONTEND_URL=http://localhost:5173

# AI (OpenRouter)
AI_ENABLED=true
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=qwen/qwen3-235b-a22b
OPENROUTER_HTTP_REFERER=http://localhost:5173
OPENROUTER_APP_NAME=ApprovalSystem
